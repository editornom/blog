---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BentoGrid from "@/components/BentoGrid.astro";
import getSortedPosts from "@/utils/getSortedPosts";

const posts = await getCollection("blog", ({ id }) => 
  id.replace(/\\/g, "/").startsWith("ko/")
);

const sortedPosts = getSortedPosts(posts);

const normalPosts = sortedPosts.filter(p => p.id.replace(/\\/g, "/").includes("posts/"));

const bentoRow1 = normalPosts.slice(0, 4);
const bentoRow2 = normalPosts.slice(4, 8);
---

<Layout>
  <script is:inline>
    // 브라우저 언어 감지 자동 리다이렉트 (복구됨)
    if (window.location.pathname === '/' || window.location.pathname === '') {
      const lang = navigator.language || navigator.userLanguage;
      const shortLang = lang ? lang.split('-')[0].toLowerCase() : 'en';
      
      let target = '/en';
      if (shortLang === 'ko') target = '/ko';
      else if (shortLang === 'ja') target = '/jp';
      else if (shortLang === 'zh') target = '/cn';
      
      window.location.replace(target);
    }
  </script>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    {
      bentoRow1.length > 0 && (
        <section id="bento-row1" class:list={["pt-8"]}>
          <BentoGrid posts={bentoRow1} />
        </section>
      )
    }

    {
      bentoRow2.length > 0 && (
        <section id="bento-row2" class:list={["mt-[10px] pb-6"]}>
          <BentoGrid posts={bentoRow2} />
        </section>
      )
    }

  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>

