---
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";

type StringTitle = { pageTitle: string };
type ArrayTitle = { pageTitle: [string, string]; titleTransition: string };

type Props = (StringTitle | ArrayTitle) & { pageDesc?: string };

const { props } = Astro;

const backUrl = SITE.showBackButton ? Astro.url.pathname : "/";
---

<Breadcrumb />
<main data-backUrl={backUrl} id="main-content" class="app-layout pb-4">
  {
    "titleTransition" in props ? (
      <h1 class="text-2xl font-semibold sm:text-3xl">
        {props.pageTitle[0]}
        <span transition:name={props.titleTransition}>
          {props.pageTitle[1]}
        </span>
      </h1>
    ) : (
      <h1 class="text-2xl font-semibold sm:text-3xl">{props.pageTitle}</h1>
    )
  }
  <p class="mt-2 mb-6 italic">{props.pageDesc}</p>
  <slot />
</main>

<script>
  document.addEventListener("astro:page-load", () => {
    const mainContent: HTMLElement | null =
      document.querySelector("#main-content");
    const backUrl = mainContent?.dataset?.backurl;
    if (backUrl) {
      sessionStorage.setItem("backUrl", backUrl);
    }
  });
</script>

<script is:inline>
  /* ========== Card view count bulk fetch ========== */
  function fetchCardViewCounts() {
    const spans = document.querySelectorAll(".card-view-count[data-slug]");
    if (!spans.length) return;

    const supabaseUrl = window.__SB_URL__;
    const supabaseKey = window.__SB_KEY__;
    if (!supabaseUrl || !supabaseKey) return;

    // Group slugs by language
    const byLang = {};
    spans.forEach(span => {
      const slug = span.dataset.slug;
      const lang = span.dataset.lang || "ko";
      if (!byLang[lang]) byLang[lang] = [];
      byLang[lang].push({ slug, span });
    });

    Object.entries(byLang).forEach(([lang, entries]) => {
      // PostgREST in() filter: no quotes around string values
      const slugList = entries.map(e => e.slug).join(",");
      fetch(`${supabaseUrl}/rest/v1/page_views?select=page_slug,view_count&page_lang=eq.${lang}&page_slug=in.(${slugList})`, {
        headers: { "apikey": supabaseKey, "Authorization": `Bearer ${supabaseKey}` }
      })
      .then(r => r.json())
      .then(rows => {
        const map = {};
        if (Array.isArray(rows)) rows.forEach(r => { map[r.page_slug] = r.view_count; });
        entries.forEach(({ slug, span }) => {
          const num = span.querySelector(".view-num");
          if (num) num.textContent = map[slug] !== undefined ? map[slug].toLocaleString() : "0";
        });
      })
      .catch(() => {});
    });
  }

  // Run on initial load and on Astro page transitions
  fetchCardViewCounts();
  document.addEventListener("astro:page-load", fetchCardViewCounts);
</script>
