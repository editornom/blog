---
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";

type StringTitle = { pageTitle: string };
type ArrayTitle = { pageTitle: [string, string]; titleTransition: string };

type Props = (StringTitle | ArrayTitle) & { pageDesc?: string };

const { props } = Astro;

const backUrl = SITE.showBackButton ? Astro.url.pathname : "/";
---

<Breadcrumb />
<main data-backUrl={backUrl} id="main-content" class="app-layout pb-4">
  {
    "titleTransition" in props ? (
      <h1 class="text-2xl font-semibold sm:text-3xl">
        {props.pageTitle[0]}
        <span transition:name={props.titleTransition}>
          {props.pageTitle[1]}
        </span>
      </h1>
    ) : (
      <h1 class="text-2xl font-semibold sm:text-3xl">{props.pageTitle}</h1>
    )
  }
  <p class="mt-2 mb-6 italic">{props.pageDesc}</p>
  <slot />
</main>

<script>
  document.addEventListener("astro:page-load", () => {
    const mainContent: HTMLElement | null =
      document.querySelector("#main-content");
    const backUrl = mainContent?.dataset?.backurl;
    if (backUrl) {
      sessionStorage.setItem("backUrl", backUrl);
    }
  });
</script>

<script>
  import { supabase } from "@/utils/supabase";

  async function fetchCardViewCounts() {
    const spans = document.querySelectorAll<HTMLElement>(".card-view-count[data-slug]");
    if (!spans.length) return;

    // Group by language
    const byLang = new Map<string, { slug: string; span: HTMLElement; numEl: HTMLElement | null }[]>();
    spans.forEach(span => {
      const slug = span.dataset.slug || "";
      const lang = span.dataset.lang || "ko";
      if (!byLang.has(lang)) byLang.set(lang, []);
      byLang.get(lang)!.push({ slug, span, numEl: span.querySelector(".view-num") });
    });

    for (const [lang, entries] of byLang) {
      const slugs = entries.map(e => e.slug);
      const { data, error } = await supabase
        .from("page_views")
        .select("page_slug, view_count")
        .eq("page_lang", lang)
        .in("page_slug", slugs);

      if (!error && Array.isArray(data)) {
        const countMap: Record<string, number> = {};
        data.forEach(row => { countMap[row.page_slug] = row.view_count; });
        entries.forEach(({ slug, numEl }) => {
          if (numEl) {
            const count = countMap[slug];
            numEl.textContent = count !== undefined ? count.toLocaleString() : "0";
          }
        });
      }
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", fetchCardViewCounts);
  } else {
    fetchCardViewCounts();
  }
  document.addEventListener("astro:after-swap", fetchCardViewCounts);
</script>
