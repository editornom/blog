---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";

import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import tz from "dayjs/plugin/timezone";
dayjs.extend(utc);
dayjs.extend(tz);
import { SITE } from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  hideEditPost,
} = post.data;

const { Content } = await render(post);

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

let faqSchema: Record<string, any> | undefined;

if (post.data.faqs && post.data.faqs.length > 0) {
  faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": post.data.faqs.map(item => ({
      "@type": "Question",
      "name": item.q.trim(),
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a.trim().replace(/\n/g, " ")
      }
    }))
  };
}

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
  faqSchema,
};

/* ========== Post List for bottom navigation ========== */
const ITEMS_PER_PAGE = 4;

// Detect which board the current post belongs to (posts/ or haionnet/ or glossary/)
const normalizedId = post.id.replace(/\\/g, "/");
const currentBoard = normalizedId.includes("haionnet/") ? "haionnet/" 
  : normalizedId.includes("glossary/") ? "glossary/" 
  : "posts/";

const postListData = posts
  .filter(p => p.id !== post.id && p.id.replace(/\\/g, "/").includes(currentBoard))
  .map(p => {
    let thumb = "";
    if (typeof p.data.ogImage === "string") {
      thumb = p.data.ogImage;
    } else if (p.data.ogImage?.src) {
      thumb = p.data.ogImage.src;
    }
    const d = dayjs(p.data.modDatetime && p.data.modDatetime > p.data.pubDatetime ? p.data.modDatetime : p.data.pubDatetime).tz(p.data.timezone || SITE.timezone);
    return {
      title: p.data.title,
      slug: p.data.slug,
      href: getPath(p.id, p.filePath),
      thumb,
      date: d.format("YYYY.MM.DD"),
    };
  });

const totalPages = Math.ceil(postListData.length / ITEMS_PER_PAGE);
const currentLang = Astro.url.pathname.split("/")[1] || "ko";

const UI_TEXT = {
  ko: { otherPosts: "다른 글 보기", prev: "← 이전", next: "다음 →" },
  en: { otherPosts: "Other Posts", prev: "← Prev", next: "Next →" },
  jp: { otherPosts: "他の記事", prev: "← 前へ", next: "次へ →" },
  cn: { otherPosts: "其他文章", prev: "← 上一页", next: "下一页 →" },
};
const t = UI_TEXT[currentLang as keyof typeof UI_TEXT] || UI_TEXT.ko;
---

<Layout {...layoutProps}>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    <h1
      transition:name={slugifyStr(title.replaceAll(".", "-"))}
      class="inline-block text-2xl font-bold text-accent sm:text-3xl"
    >
      {title}
    </h1>
    <div class="my-2 flex items-center gap-2">
      <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
      <span
        id="view-count-container"
        class="flex items-center gap-1.5 text-sm text-foreground/75 opacity-85"
        data-slug={post.data.slug}
        data-lang={Astro.url.pathname.split("/")[1]}
      >
        <span aria-hidden="true" class="opacity-50">|</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"></path>
          <path
            d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"
          ></path>
        </svg>
        <span id="view-count">--</span>
      </span>
      <span
        aria-hidden="true"
        class:list={[
          "max-sm:hidden",
          { hidden: !SITE.editPost.enabled || hideEditPost },
        ]}>|</span
      >
      <EditPost {hideEditPost} {post} class="max-sm:hidden" />
    </div>
    <article
      id="article"
      class="app-prose mt-8 w-full max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
    >
      <Content />
      {post.data.faqs && post.data.faqs.length > 0 && (
        <div class="faq-section mt-12">
          <h2 class="text-xl font-bold mb-4">✅ 자주 묻는 질문 (FAQ)</h2>
          {post.data.faqs.map((item) => (
            <details class="group border-b border-border py-2">
              <summary class="cursor-pointer font-medium list-none flex items-center justify-between">
                <span>{item.q}</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="faq-content mt-2 text-foreground/80 leading-relaxed whitespace-pre-wrap">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      )}
      
      {post.data.references && post.data.references.length > 0 && (
        <div class="references-section mt-12">
          <details class="group transition-all opacity-80 hover:opacity-100">
            <summary class="cursor-pointer font-medium flex items-center justify-between list-none py-2 border-b border-border/50">
              <span class="flex items-center gap-2 text-foreground/70">
                📚 <span class="group-open:hidden">참고 자료 확인하기</span>
                <span class="hidden group-open:inline">정보 출처 및 관련 문서</span>
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <ul class="mt-3 space-y-2 px-1">
              {post.data.references.map((url, i) => (
                <li class="flex gap-2 text-sm text-foreground/75 overflow-hidden">
                  <span class="font-bold flex-none">{i + 1}:</span>
                  <a href={url} target="_blank" rel="noopener noreferrer" class="truncate hover:text-accent border-b border-transparent hover:border-accent">
                    {url.replace(/^https?:\/\//, '')}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        </div>
      )}
    </article>

    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />




    <ShareLinks />

    <hr class="my-6 border-dashed" />

    <!-- Post List Navigation -->
    <section id="post-list-nav" data-pagefind-ignore data-total-pages={totalPages} data-lang={currentLang} data-sb-url={import.meta.env.PUBLIC_SUPABASE_URL || ""} data-sb-key={import.meta.env.PUBLIC_SUPABASE_ANON_KEY || ""}>
      <h2 class="mb-4 text-lg font-semibold text-foreground">{t.otherPosts}</h2>
      <ul id="post-list-items" class="flex flex-col gap-2">
        {postListData.map((p, i) => (
          <li
            class="post-list-item rounded-lg border border-border bg-muted/10 transition-all hover:bg-muted/30"
            data-page={Math.floor(i / ITEMS_PER_PAGE)}
            style={i >= ITEMS_PER_PAGE ? "display:none" : ""}
          >
            <a href={p.href} class="flex items-center gap-3 p-2.5 no-underline sm:gap-4 sm:p-3">
              <div class="h-12 w-12 flex-none overflow-hidden rounded-md bg-muted sm:h-14 sm:w-14">
                {p.thumb ? (
                  <img src={p.thumb} alt={p.title} class="h-full w-full object-cover" loading="lazy" />
                ) : (
                  <div class="flex h-full w-full items-center justify-center bg-accent/10 text-xs text-accent">N</div>
                )}
              </div>
              <div class="flex min-w-0 flex-1 flex-col gap-0.5">
                <span class="truncate text-sm font-medium text-foreground sm:text-base">{p.title}</span>
                <div class="flex items-center gap-2 text-xs text-foreground/50">
                  <span>{p.date}</span>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
      {totalPages > 1 && (
        <div id="post-list-pagination" class="mt-4 flex items-center justify-center gap-3">
          <button id="pl-prev" class="rounded-md border border-border px-3 py-1.5 text-sm text-foreground/70 transition-colors hover:bg-muted/40 disabled:opacity-30 disabled:cursor-not-allowed" disabled>
            {t.prev}
          </button>
          <span class="text-sm text-foreground/60">
            <span id="pl-current">1</span> / {totalPages}
          </span>
          <button id="pl-next" class="rounded-md border border-border px-3 py-1.5 text-sm text-foreground/70 transition-colors hover:bg-muted/40 disabled:opacity-30 disabled:cursor-not-allowed">
            {t.next}
          </button>
        </div>
      )}
    </section>
  </main>
  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      // Check if --file-name-offset custom property exists
      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      // Determine the top positioning class
      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap codebock with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that task is completed
      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  /* Go to page start after page swap */
  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>

<script>
  import { supabase } from "@/utils/supabase";

  async function updateViewCount() {
    const viewCountElement = document.getElementById("view-count");
    const container = document.getElementById("view-count-container");

    if (!viewCountElement || !container) return;

    const slug = container.dataset.slug;
    const lang = container.dataset.lang || window.location.pathname.split("/")[1];

    if (slug && lang) {
      try {
        // Calling Supabase RPC to increment and get updated count
        const { data, error } = await supabase.rpc("increment_views", {
          page_slug: slug,
          page_lang: lang,
        });

        if (error) {
          console.error(`[Supabase Error] increment_views for ${slug}:`, error);
          viewCountElement.innerText = "0";
        } else {
          // Double check the data returned from the RPC
          console.log(`[Supabase Response] data for ${slug}:`, data);
          
          if (data !== null && data !== undefined) {
            viewCountElement.innerText = data.toString();
          } else {
            // Fallback if the SQL function doesn't RETURN new_count
            console.warn(`[Supabase Warning] RPC returned null for ${slug}. Check if SQL function has 'RETURN new_count;'`);
            // Attempt a fallback or just keep it as 1 (assuming it was just incremented)
            if (viewCountElement.innerText === "--") {
                 viewCountElement.innerText = "1";
            }
          }
        }
      } catch (err) {
        console.error(`[Supabase Exception] for ${slug}:`, err);
        viewCountElement.innerText = "0";
      }
    }
  }

  // Double check the DOM is ready for the first load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", updateViewCount);
  } else {
    updateViewCount();
  }

  // Support Astro View Transitions
  document.addEventListener("astro:after-swap", updateViewCount);
</script>

<script is:inline data-astro-rerun>
  /* ========== Post List Pagination ========== */
  (function initPostListNav() {
    const nav = document.getElementById("post-list-nav");
    if (!nav) return;

    const totalPages = parseInt(nav.dataset.totalPages || "1", 10);
    const lang = nav.dataset.lang || "ko";
    const items = document.querySelectorAll(".post-list-item");
    const prevBtn = document.getElementById("pl-prev");
    const nextBtn = document.getElementById("pl-next");
    const currentLabel = document.getElementById("pl-current");
    let currentPage = 0;

    function showPage(page) {
      currentPage = page;
      items.forEach(item => {
        item.style.display = parseInt(item.dataset.page, 10) === page ? "" : "none";
      });
      if (currentLabel) currentLabel.textContent = (page + 1).toString();
      if (prevBtn) prevBtn.disabled = page === 0;
      if (nextBtn) nextBtn.disabled = page >= totalPages - 1;
    }

    if (prevBtn) prevBtn.addEventListener("click", () => { if (currentPage > 0) showPage(currentPage - 1); });
    if (nextBtn) nextBtn.addEventListener("click", () => { if (currentPage < totalPages - 1) showPage(currentPage + 1); });

    showPage(0);

    /* ========== Bulk fetch view counts for listed posts ========== */
    const viewSpans = document.querySelectorAll(".post-views[data-slug]");
    if (viewSpans.length === 0) return;

    const slugs = Array.from(viewSpans).map(s => s.dataset.slug);

    // Use Supabase REST API directly to get view counts
    const supabaseUrl = nav.dataset.sbUrl;
    const supabaseKey = nav.dataset.sbKey;

    const viewCountTexts = {
      ko: { views: count => `조회 ${count}`, loading: "조회 --" },
      en: { views: count => `${count} views`, loading: "Views --" },
      jp: { views: count => `閲覧 ${count}`, loading: "閲覧 --" },
      cn: { views: count => `阅读 ${count}`, loading: "阅读 --" }
    };
    const tViews = viewCountTexts[lang] || viewCountTexts.ko;

    if (!supabaseUrl || !supabaseKey) {
      // Fallback: try reading from existing supabase client via window
      viewSpans.forEach(s => { s.textContent = tViews.loading; });
      return;
    }

    fetch(`${supabaseUrl}/rest/v1/page_views?select=page_slug,view_count&page_lang=eq.${lang}&page_slug=in.(${slugs.map(s => `"${s}"`).join(",")})`, {
      headers: {
        "apikey": supabaseKey,
        "Authorization": `Bearer ${supabaseKey}`
      }
    })
    .then(res => res.json())
    .then(data => {
      const countMap = {};
      if (Array.isArray(data)) {
        data.forEach(row => { countMap[row.page_slug] = row.view_count; });
      }
      viewSpans.forEach(span => {
        const count = countMap[span.dataset.slug];
        span.textContent = count !== undefined ? tViews.views(count) : tViews.views(0);
      });
    })
    .catch(() => {
      viewSpans.forEach(s => { s.textContent = tViews.loading; });
    });
  })();
</script>
