---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ogImage: initOgImage, slug, ...props } = data;

// Resolve thumbnail URL
let thumbSrc = "";
if (typeof initOgImage === "string") {
  thumbSrc = initOgImage;
} else if (initOgImage?.src) {
  thumbSrc = initOgImage.src;
}

// Detect language and type from post id
const normalizedId = id.replace(/\\/g, "/");
const lang = normalizedId.split("/")[0] || "ko";
const isGlossary = normalizedId.includes("/glossary/");
---

<li class="group my-4">
  <a
    href={getPath(id, filePath)}
    class="flex gap-4 rounded-xl border border-border bg-muted/5 p-3 transition-all duration-200 hover:bg-muted/20 hover:shadow-sm no-underline sm:p-4"
  >
    <!-- Thumbnail -->
    {!isGlossary && (
      <div class="h-20 w-20 flex-none overflow-hidden rounded-lg bg-muted sm:h-24 sm:w-24">
        {thumbSrc ? (
          <img
            src={thumbSrc}
            alt={title}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center bg-accent/10 text-2xl text-accent/40">
            ✦
          </div>
        )}
      </div>
    )}

    <!-- Content -->
    <div class="flex min-w-0 flex-1 flex-col justify-between">
      <div>
        <Heading
          class="line-clamp-2 text-base font-semibold leading-snug text-accent transition-colors group-hover:text-accent/80 sm:text-lg"
          style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
        >
          {title}
        </Heading>
        <p class="mt-1 line-clamp-2 text-xs text-foreground/60 sm:text-sm">
          {description}
        </p>
      </div>

      <!-- Meta: date -->
      <div class="mt-2 flex items-center gap-3 text-xs text-foreground/45">
        <Datetime {...props} />
      </div>
    </div>
  </a>
</li>

<style>
  /* Remove default list styles from parent ul when cards are used */
  :global(ul:has(> li > a.no-underline)) {
    padding: 0;
    list-style: none;
  }
</style>
