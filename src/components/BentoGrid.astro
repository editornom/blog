---
import type { CollectionEntry } from "astro:content";
import BentoCard from "./BentoCard.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
const bigPost = posts[0];
const smallPosts = posts.slice(1, 4);
---

<div class="flex flex-col gap-[2px] py-8">
  {/* Big Post (Most Recent) */}
  {bigPost && (
    <div class="w-full">
      <BentoCard post={bigPost} isLarge={true} />
    </div>
  )}

  {/* Small Posts (Next 3 in a grid) */}
  <div class="grid grid-cols-1 gap-[2px] sm:grid-cols-2 lg:grid-cols-3">
    {smallPosts.map((post) => (
      <BentoCard post={post} />
    ))}
  </div>
</div>

<style>
  /* Optional: Ensure the grid has a consistent height on desktop if needed */
  @media (min-width: 1024px) {
    .grid {
      grid-template-areas: 
        "big big small1"
        "big big small2"
        "small3 small3 small3" /* Or just keep them in a column */
    }
  }
</style>
