---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";
import getFirstImage from "@/utils/getFirstImage";

interface Props {
  post: CollectionEntry<"blog">;
  isLarge?: boolean;
}

const { post, isLarge = false } = Astro.props;
const { title, description, ogImage, ...datetimeProps } = post.data;

// Resolve the thumbnail:
// 1. If ogImage is already a resolved object (from Astro schema), use it.
// 2. Otherwise, use getFirstImage and try to resolve it.
let thumbnail: any = ogImage;

if (!thumbnail || typeof thumbnail === "string") {
  const bodyImage = getFirstImage(post.body || "");
  const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/images/**/*.{jpeg,jpg,png,gif,webp}"
  );

  // Try to find the matching image in the assets
  for (const path in images) {
    if (path.endsWith(bodyImage.split("/").pop()!)) {
      thumbnail = (await images[path]()).default;
      break;
    }
  }
}

const transitionName = slugifyStr(title.replaceAll(".", "-"));
---

<a
  href={getPath(post.id, post.filePath)}
  class:list={[
    "group bg-skin-card relative flex flex-col overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl",
    "aspect-square w-full",
    isLarge ? "col-span-3 row-span-3" : "col-span-1",
  ]}
>
  {/* Thumbnail Background */}
  <div class="bg-skin-fill absolute inset-0 z-0">
    {
      thumbnail ? (
        <Image
          src={thumbnail}
          alt={title}
          width={isLarge ? 1000 : 600}
          height={isLarge ? 1000 : 600}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
      ) : (
        <div class="from-skin-accent/20 to-skin-fill h-full w-full bg-gradient-to-br" />
      )
    }
    <div
      class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/15 to-transparent"
    >
    </div>
  </div>

  {/* Content */}
  <div
    class:list={[
      "relative z-10 flex h-full flex-col justify-end p-6 text-white",
      isLarge ? "sm:p-8" : "p-4",
    ]}
  >
    {
      isLarge && (
        <div class="mb-2 flex items-center gap-2 decoration-dashed opacity-80">
          <Datetime {...datetimeProps} />
        </div>
      )
    }

    <h3
      class:list={[
        "line-clamp-2 leading-tight font-bold transition-colors group-hover:text-accent",
        isLarge ? "text-2xl md:text-3xl" : "text-lg",
      ]}
      style={{ viewTransitionName: transitionName }}
    >
      {title}
    </h3>

    {
      isLarge && (
        <p class="mt-3 line-clamp-2 text-sm opacity-90 md:text-base">
          {description}
        </p>
      )
    }
  </div>
</a>
